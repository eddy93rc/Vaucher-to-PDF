# Monday.com API (requerido para setup-monday.js)
MONDAY_API_TOKEN=tu_token_aqui
MONDAY_API_URL=https://api.monday.com/v2

# Opcional: ID del workspace donde crear el board (ej: 14176200 para IT)
MONDAY_WORKSPACE_ID=14176200

# PDF Extractor (OpenAI) - reemplaza Parseur
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Parseur API (legacy, opcional si usas pdf-extractor)
PARSEUR_API_KEY=sk_...
PARSEUR_API_URL=https://api.parseur.com
PARSEUR_MAILBOX_NAME=Ticket Aereo

# Monday board ID (usar 18404261128 para el board nuevo; ejecutar setup-monday.js para crear columnas)
MONDAY_BOARD_ID=18404261128

# Columna donde se sube el PDF del voucher generado (vaucher-to-pdf). Ej: file_mm1h5b78
MONDAY_VOUCHER_PDF_COLUMN_ID=file_mm1h5b78

# Columna Archivo ticket (para n8n, extracción). Ej: file_mm1hzrw2
# MONDAY_TICKET_COLUMN_ID=file_mm1hzrw2


