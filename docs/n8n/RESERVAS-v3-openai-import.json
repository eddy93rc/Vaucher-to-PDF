      "parameters": {
        "authentication": "headerAuth",
        "endpoint": "https://api.monday.com/v2/",
        "requestFormat": "json",
        "query": "query GetAssetPublicUrl($assetIds: [ID!]!) {\n  assets(ids: $assetIds) {\n    public_url\n  }\n}",
        "variables": "={{ {\n  assetIds: [ $json.assetId ]\n} }}",
