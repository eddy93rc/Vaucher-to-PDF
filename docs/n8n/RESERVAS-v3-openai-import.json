    {
      "parameters": {
        "jsCode": "// Validamos que \"data\" y \"items\" estén definidos antes de acceder a \"column_values\"\nconst items = $json[\"data\"]?.[\"items\"] || [];  \n\n// Si no hay items, retornamos un array vacío con error\nif (items.length === 0) {\n  return [{ json: { error: \"No items found in the webhook data\" } }];\n}\n\n// Inicializamos un array para almacenar los archivos encontrados\nlet filesToDownload = [];\n\n// Iteramos sobre todos los items recibidos\nfor (let item of items) {\n  const columnValues = item[\"column_values\"] || [];\n\n  for (let col of columnValues) {\n    if (col.value) {\n      try {\n        // Parseamos el valor JSON de la columna\n        const parsedValue = JSON.parse(col.value);\n        const files = parsedValue.files || [];\n\n        // Agregamos cada archivo a la lista de archivos a descargar\n        files.forEach(file => {\n          filesToDownload.push({\n            json: {\n              assetId: file.assetId,\n              fileName: file.name\n            }\n          });\n        });\n      } catch (error) {\n        console.log(\"Error al parsear la columna 'file':\", error);\n      }\n    }\n  }\n}\n\n// Si no hay archivos para descargar, retornamos un mensaje\nif (filesToDownload.length === 0) {\n  return [{ json: { error: \"No files found in the columns\" } }];\n}\n\n// Devolvemos los archivos a n8n para su procesamiento posterior\nreturn filesToDownload;"
      },
