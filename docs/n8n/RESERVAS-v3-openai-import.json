nst map = { ok: 'Confirmado', confirmado: 'Confirmado', pendiente: 'Pendiente', cancelado: 'Cancelado', cambiado: 'Cambiado' }; return map[v] || 'Confirmado'; })() } : undefined,\n      text_mm1hzhq6: $json.baggage || '',\n      text_mm1hwrt9: $json.fare_basis || '',\n      text_mm1h94ne: $json.ticket_number || '',\n      text_mm1ha8fn: $json.seat || '-',\n      long_text_mm1h4jjb: ($json.seat_assignments && String($json.seat_assignments).trim()) ? { text: $json.seat_assignments } : undefined\n    }).filter(([_, v]) => v !== undefined)))\n  }\n} }}",
