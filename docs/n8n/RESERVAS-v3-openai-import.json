    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const result = [];\n\nif (Array.isArray($json)) {\n  $json.forEach(item => {\n    if (item.data && Array.isArray(item.data.assets)) {\n      item.data.assets.forEach(asset => {\n        if (asset.public_url) {\n          result.push({ json: { public_url: asset.public_url } });\n        }\n      });\n    }\n  });\n} else {\n  if ($json.data && Array.isArray($json.data.assets)) {\n    $json.data.assets.forEach(asset => {\n      if (asset.public_url) {\n        result.push({ json: { public_url: asset.public_url } });\n      }\n    });\n  }\n}\n\n// Devolver un objeto con el array dentro para facilitar su uso en n8n\nreturn {\n  json: {\n    urls: result\n  }\n};"
      },
