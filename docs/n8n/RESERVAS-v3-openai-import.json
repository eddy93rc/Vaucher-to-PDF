        "jsCode": "\nfunction asString(value) {\n  if (value == null) return '';\n  return String(value).trim();\n}\n\nfunction normalizeIataName(raw) {\n  const value = asString(raw)\n    .replace(/\\b(MR|MRS|MS|MISS|SR|SRA|DR|ADT|CHD|INF)\\b/gi, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  if (!value) return '';\n  if (value.includes('/')) {\n    return value\n      .toUpperCase()\n      .replace(/[^A-Z0-9/]/g, '')\n      .replace(/\\/{2,}/g, '/');\n  }\n  const parts = value.split(' ').filter(Boolean);\n  if (parts.length === 1) return parts[0].toUpperCase();\n  const firstName = parts.slice(-2).join('').toUpperCase();\n  const lastName = parts.slice(0, Math.max(parts.length - 2, 1)).join('').toUpperCase();\n  return lastName && firstName ? lastName + '/' + firstName : value.toUpperCase().replace(/[^A-Z0-9/]/g, '');\n}\n\nfunction getPassengerFull(raw) {\n  if (!raw) return '';\n  if (typeof raw === 'string') {\n    try {\n      const parsed = JSON.parse(raw);\n      return parsed.full || raw;\n    } catch {\n      return raw;\n    }\n  }\n  if (typeof raw === 'object') {\n    return raw.full || [raw.first, raw.middle, raw.last].filter(Boolean).join(' ');\n  }\n  return String(raw);\n}\n\nfunction unique(values) {\n  const seen = new Set();\n  const out = [];\n  for (const raw of values) {\n    const value = asString(raw);\n    if (!value) continue;\n    const key = value.toUpperCase();\n    if (seen.has(key)) continue;\n    seen.add(key);\n    out.push(value);\n  }\n  return out;\n}\n\nconst payload = $json.full_payload || {};\nconst passengers = Array.isArray($json.passengers) ? $json.passengers : [];\nconst segments = Array.isArray($json.segments) ? $json.segments : [];\nconst reservationCode = asString($json.reservation_code);\nconst globalTicket = asString($json.ticket_number).replace(/\\s+/g, ' ').trim();\n\nif (!reservationCode) throw new Error('Parseur: falta reservation_code');\nif (!passengers.length) throw new Error('Parseur: faltan pasajeros');\nif (!segments.length) throw new Error('Parseur: faltan segmentos');\n\nconst normalizedPassengers = passengers.map((passenger, index) => {\n  const passengerFull = asString(getPassengerFull(passenger.passenger_name || passenger.name || ''));\n  const passengerVoucher = normalizeIataName(passenger.passenger_voucher || passengerFull);\n  const passengerTicket = asString(passenger.ticket_number || globalTicket).replace(/\\s+/g, ' ').trim();\n  return {\n    passenger_number: passenger.passenger_number || index + 1,\n    passenger_name: passengerFull,\n    passenger_voucher: passengerVoucher,\n    passenger_type: asString(passenger.passenger_type || 'ADT'),\n    ticket_number: passengerTicket,\n  };\n});\n\nconst ticketCount = normalizedPassengers.filter((p) => p.ticket_number).length;\nif (normalizedPassengers.length > 1 && ticketCount < normalizedPassengers.length && !globalTicket) {\n  throw new Error('Parseur: hay mas pasajeros que tickets utilizables');\n}\n\nconst normalizedSegments = segments.map((segment, index) => {\n  const departureDate = asString(segment.departure_date);\n  const departureTime = asString(segment.departure_time || '00:00');\n  const arrivalDate = asString(segment.arrival_date);\n  const arrivalTime = asString(segment.arrival_time || '00:00');\n  if (departureDate && arrivalDate) {\n    const dep = new Date(departureDate + 'T' + departureTime.slice(0, 5));\n    const arr = new Date(arrivalDate + 'T' + arrivalTime.slice(0, 5));\n    if (!Number.isNaN(dep.getTime()) && !Number.isNaN(arr.getTime()) && arr.getTime() < dep.getTime()) {\n      throw new Error('Parseur: fechas u horas imposibles en segmento ' + (segment.segment_number || index + 1));\n    }\n  }\n  const marketingAirline = asString(segment.marketing_airline || segment.operated_by || payload.airline_main);\n  const operatedBy = asString(segment.operated_by || marketingAirline || payload.airline_main);\n  return {\n    ...segment,\n    segment_number: segment.segment_number || index + 1,\n    marketing_airline: marketingAirline,\n    operated_by: operatedBy,\n    ticket_number: asString(segment.ticket_number || globalTicket),\n    seat: asString(segment.seat || '-'),\n    seat_assignments: asString(segment.seat_assignments || ''),\n    booking_status: asString(segment.booking_status || payload.booking_status || ''),\n    salida_llegada: [\n      asString(segment.origin_code),\n      departureDate,\n      departureTime,\n      '->',\n      asString(segment.destination_code),\n      arrivalDate,\n      arrivalTime,\n    ].filter(Boolean).join(' '),\n  };\n});\n\nconst airlinesInvolvedList = unique([\n  ...(Array.isArray(payload.airlines_involved) ? payload.airlines_involved : asString($json.airlines_involved).split(/[\\n,;]+/)),\n  payload.airline_main,\n  ...normalizedSegments.flatMap((segment) => [segment.marketing_airline, segment.operated_by]),\n]);\n\nconst formattedPassengersList = normalizedPassengers\n  .map((passenger) => passenger.ticket_number ? passenger.passenger_voucher + ' - ' + passenger.ticket_number : passenger.passenger_voucher)\n  .filter(Boolean)\n  .join('\\n');\n\nconst primaryPassenger = normalizedPassengers[0] || {};\nconst extras = [\n  'PRESENTARSE EN AEROPUERTO CON TIEMPO SUFICIENTE PARA CHECK-IN Y SEGURIDAD.',\n  'VALIDAR REQUISITOS MIGRATORIOS, VISA Y VIGENCIA MINIMA DEL PASAPORTE.',\n  'REVISAR POLITICAS DE CAMBIO, CANCELACION Y EQUIPAJE ANTES DEL VIAJE.',\n];\nconst agencyPhone = asString(payload.agency_phone || payload.agency_emergency_phone || payload.telefono_agencia || '849-919-1919');\nif (agencyPhone) extras.push('EN CASO DE EMERGENCIA CONTACTAR A LA AGENCIA AL ' + agencyPhone + '.');\n\nreturn [{\n  json: {\n    ...$json,\n    passengers: normalizedPassengers,\n    passenger_full_name: primaryPassenger.passenger_name || asString(getPassengerFull(payload.passenger_name || '')),\n    passenger_voucher_primary: primaryPassenger.passenger_voucher || normalizeIataName(primaryPassenger.passenger_name || payload.passenger_name || ''),\n    primary_ticket_number: primaryPassenger.ticket_number || globalTicket,\n    formatted_passengers_list: formattedPassengersList,\n    airlines_involved_list: airlinesInvolvedList,\n    airlines_involved_text: airlinesInvolvedList.join('\\n'),\n    extras_text: extras.join('\\n'),\n    segments: normalizedSegments,\n    full_payload: {\n      ...payload,\n      passengers: normalizedPassengers,\n      segments: normalizedSegments,\n      airlines_involved: airlinesInvolvedList,\n    }\n  }\n}];"
